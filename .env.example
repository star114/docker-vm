# teslamate
ENCRYPTION_KEY=key

# DB configuration
DB_NAME=teslamate
DB_USER=teslamate
DB_PASSWORD=change_this_secure_password_123!
DB_PORT=5432

# Persistent host paths
DATA_ROOT=/srv/docker-data
BACKUP_ROOT=/srv/docker-backups

# Image versions
NPM_IMAGE_TAG=2.14.0
VAULTWARDEN_IMAGE_TAG=1.35.2
POSTGRES_IMAGE_TAG=17.9-trixie
TESLAMATE_IMAGE_TAG=3.0.0
TESLAMATE_GRAFANA_IMAGE_TAG=3.0.0
PORTAINER_IMAGE_TAG=2.39.0
DIUN_IMAGE_TAG=4.30.0

# Diun notifications
DIUN_TELEGRAM_BOT_TOKEN=123456789:replace_me
DIUN_TELEGRAM_CHAT_IDS=123456789

# MQTT
MQTT_HOST=mqtt
MQTT_USERNAME=teslamate
MQTT_PASSWORD=change_this_secure_password_123!

# grafana
GF_PASSWORD=change_this_secure_password_123!
GF_ADMIN_USER=teslamate
GF_ADMIN_PASSWORD=change_this_secure_password_123!
